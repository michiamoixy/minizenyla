// ===== AGENT MODE: FASE 1 + FASE 2 + FASE 3 + FASE 4 =====

function analyzeCode() {
    let code = document.getElementById("codeInput").value.trim();
    
    if(!code) {
        alert("Incolla il codice!");
        return;
    }
    
    agentData.originalCode = code;
    
    // FASE 2: Analizza
    let lines = code.split('\n').length;
    let language = detectLanguage(code);
    let functions = (code.match(/function\s+\w+|const\s+\w+\s*=\s*\(|def\s+\w+/g) || []).length;
    let errors = detectErrors(code);
    
    agentData.analysis = { lines, language, functions, errors };
    
    // Mostra analisi
    let analysisHTML = `
        <div class="analysis-box"><strong>📊 Linguaggio:</strong> ${language}</div>
        <div class="analysis-box"><strong>📝 Linee:</strong> ${lines}</div>
        <div class="analysis-box"><strong>⚙️ Funzioni:</strong> ${functions}</div>
        <div class="analysis-box"><strong>⚠️ Errori:</strong> ${errors.join(", ")}</div>
    `;
    
    document.getElementById("analysisResult").innerHTML = analysisHTML;
    
    // FASE 2: Piano
    let plan = [
        "1️⃣ Analizzare la struttura del codice",
        "2️⃣ Controllare gli errori di sintassi",
        "3️⃣ Ottimizzare le performance",
        "4️⃣ Aggiungere commenti esplicativi",
        "5️⃣ Formattare e pulire il codice"
    ];
    
    let planHTML = plan.map(p => `<div class="step-item">${p}</div>`).join("");
    document.getElementById("planResult").innerHTML = planHTML;
    
    salva("Zenyla", `✅ Analisi completata! ${language} | ${lines} linee`);
}

function executeModifications() {
    if(!agentData.originalCode) {
        alert("Analizza il codice prima!");
        return;
    }
    
    let code = agentData.originalCode;
    
    // FASE 3: Esegui modifiche
    code = addComments(code);
    code = formatCode(code);
    code = optimizeCode(code);
    
    agentData.modifiedCode = code;
    
    // Mostra output
    document.getElementById("modifiedCode").innerHTML = `<pre>${escapeHtml(code)}</pre>`;
    
    // Mostra diff
    showDiff(agentData.originalCode, code);
    
    // Aggiorna steps
    let planHTML = [
        "1️⃣ Analizzare la struttura del codice ✓",
        "2️⃣ Controllare gli errori di sintassi ✓",
        "3️⃣ Ottimizzare le performance ✓",
        "4️⃣ Aggiungere commenti esplicativi ✓",
        "5️⃣ Formattare e pulire il codice ✓"
    ].map(p => `<div class="step-item done">${p}</div>`).join("");
    
    document.getElementById("planResult").innerHTML = planHTML;
    
    salva("Zenyla", "✅ Modifiche applicate! Scarica o copia il codice.");
}

function addComments(code) {
    let lines = code.split('\n');
    let result = [];
    let commentAdded = false;
    
    lines.forEach(line => {
        if((line.includes("function") || line.includes("const") || line.includes("def")) && !commentAdded) {
            result.push("// Funzione modificata");
            commentAdded = true;
        }
        result.push(line);
    });
    
    return result.join('\n');
}

function formatCode(code) {
    return code
        .replace(/\n\s*\n/g, '\n')
        .split('\n')
        .map(line => line.trim())
        .filter(line => line.length > 0)
        .join('\n');
}

function optimizeCode(code) {
    return code
        .replace(/var\s+/g, 'const ')
        .replace(/  +/g, '  ');
}

function showDiff(original, modified) {
    let origLines = original.split('\n');
    let modLines = modified.split('\n');
    
    let diffHtml = '';
    
    let maxLines = Math.max(origLines.length, modLines.length);
    for(let i = 0; i < Math.min(maxLines, 10); i++) {
        if(origLines[i] !== modLines[i]) {
            if(origLines[i]) diffHtml += `<div class="diff-remove">- ${escapeHtml(origLines[i])}</div>`;
            if(modLines[i]) diffHtml += `<div class="diff-add">+ ${escapeHtml(modLines[i])}</div>`;
        }
    }
    
    if(maxLines > 10) diffHtml += `<div style="color: #ffd700;">... e altri ${maxLines - 10} righe</div>`;
    
    document.getElementById("diffResult").innerHTML = `<div class="diff">${diffHtml || "Nessuna differenza"}</div>`;
}

function copyCode() {
    if(!agentData.modifiedCode) {
        alert("Esegui le modifiche prima!");
        return;
    }
    
    navigator.clipboard.writeText(agentData.modifiedCode).then(() => {
        alert("✅ Codice copiato!");
        salva("Zenyla", "📋 Codice copiato negli appunti!");
    }).catch(() => {
        alert("Errore nella copia!");
    });
}

function downloadCode() {
    if(!agentData.modifiedCode) {
        alert("Esegui le modifiche prima!");
        return;
    }
    
    let filename = `zenyla_${agentData.analysis.language}_${Date.now()}.txt`;
    let element = document.createElement("a");
    element.setAttribute("href", "data:text/plain;charset=utf-8," + encodeURIComponent(agentData.modifiedCode));
    element.setAttribute("download", filename);
    element.style.display = "none";
    document.body.appendChild(element);
    element.click();
    document.body.removeChild(element);
    salva("Zenyla", `⬇️ Scaricato: ${filename}`);
}

function detectLanguage(code) {
    if(code.includes("function ") || code.includes("const ") || code.includes("let ")) return "JavaScript";
    if(code.includes("def ") || code.includes("import ")) return "Python";
    if(code.includes("class ") && code.includes("public ")) return "Java";
    if(code.includes("<!DOCTYPE") || code.includes("<html")) return "HTML";
    if(code.includes("body {")) return "CSS";
    return "Unknown";
}

function detectErrors(code) {
    let errors = [];
    if((code.match(/\(/g) || []).length !== (code.match(/\)/g) || []).length) errors.push("Parentesi");
    if((code.match(/\{/g) || []).length !== (code.match(/\}/g) || []).length) errors.push("Graffe");
    if((code.match(/\[/g) || []).length !== (code.match(/\]/g) || []).length) errors.push("Quadre");
    return errors.length > 0 ? errors : ["✓ OK"];
}

function escapeHtml(text) {
    let map = {
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
    };
    return text.replace(/[&<>"']/g, m => map[m]);
}

