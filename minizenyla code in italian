    let bingKey = document.getElementById("bingKey").value.trim();
    if(bingKey) localStorage.setItem("bing_key", bingKey);
    document.getElementById("bingKey").value = "";
    document.getElementById("apiStatus").innerHTML = "✅ Salvato!";
