<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MiniZenyla 🤖</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body{
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #151525;
    color: white;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 10px;
}

.container {
    display: flex;
    width: 100%;
    max-width: 1200px;
    gap: 10px;
    height: 90vh;
}

/* SIDEBAR SINISTRA */
.sidebar {
    background: #1a1a2e;
    width: 250px;
    border-radius: 15px;
    padding: 15px;
    overflow-y: auto;
    box-shadow: 0 0 20px rgba(108, 92, 231, 0.3);
    display: none;
}

.sidebar.active {
    display: flex;
    flex-direction: column;
}

.sidebar h3 {
    color: #6c5ce7;
    margin-bottom: 10px;
    font-size: 14px;
}

.chat-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.chat-item {
    padding: 10px;
    background: #252545;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s;
}

.chat-item:hover {
    background: #6c5ce7;
}

.chat-item.active {
    background: #6c5ce7;
    font-weight: bold;
    box-shadow: 0 0 10px #6c5ce7;
}

.chat-item .delete-btn {
    background: #ff6b6b;
    border: none;
    color: white;
    padding: 2px 6px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 11px;
    opacity: 0;
    transition: opacity 0.3s;
}

.chat-item:hover .delete-btn {
    opacity: 1;
}

/* BOX PRINCIPALE */
.box {
    background: #252545;
    flex: 1;
    padding: 20px;
    border-radius: 20px;
    box-shadow: 0 0 20px #6c5ce7;
    display: flex;
    flex-direction: column;
    max-height: 90vh;
    overflow: hidden;
}

.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 2px solid #6c5ce7;
}

h2 {
    font-size: 24px;
    flex: 1;
}

.header-buttons {
    display: flex;
    gap: 5px;
}

.header-buttons button {
    padding: 8px 12px;
    font-size: 14px;
}

#chat {
    flex: 1;
    overflow-y: auto;
    background: #111122;
    padding: 15px;
    border-radius: 10px;
    margin-bottom: 15px;
    border: 1px solid #6c5ce7;
}

.messaggio {
    margin: 10px 0;
    padding: 12px;
    border-left: 4px solid #6c5ce7;
    border-radius: 6px;
    background: rgba(108, 92, 231, 0.1);
    word-wrap: break-word;
}

.messaggio b {
    color: #6c5ce7;
}

.input-area {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
}

input[type="text"] {
    flex: 1;
    padding: 12px;
    border-radius: 8px;
    border: 1px solid #6c5ce7;
    background: #1a1a2e;
    color: white;
    font-size: 14px;
}

input[type="text"]::placeholder {
    color: #888;
}

button {
    padding: 10px 15px;
    border: none;
    border-radius: 8px;
    background: #6c5ce7;
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: bold;
}

button:hover {
    background: #7b68ee;
    transform: scale(1.05);
    box-shadow: 0 0 10px #6c5ce7;
}

button#voiceBtn.mutato {
    background: #ff6b6b;
    box-shadow: 0 0 15px #ff6b6b;
}

button#voiceBtn.attivo {
    animation: pulse 0.8s ease-in-out;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
}

/* MODALE IMPOSTAZIONI */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    z-index: 1000;
    align-items: center;
    justify-content: center;
}

.modal.active {
    display: flex;
}

.modal-content {
    background: #252545;
    border-radius: 15px;
    padding: 25px;
    width: 90%;
    max-width: 500px;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 0 30px #6c5ce7;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid #6c5ce7;
}

.modal-header h2 {
    margin: 0;
}

.close-btn {
    background: #ff6b6b;
    padding: 8px 12px;
    font-size: 18px;
}

.tab-buttons {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}

.tab-btn {
    padding: 10px 15px;
    background: #1a1a2e;
    border: 1px solid #6c5ce7;
    border-radius: 8px;
    color: white;
    cursor: pointer;
}

.tab-btn.active {
    background: #6c5ce7;
}

.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
}

.setting-item {
    margin-bottom: 15px;
}

.setting-item label {
    display: block;
    margin-bottom: 5px;
    font-weight: bold;
    font-size: 14px;
}

.setting-item input,
.setting-item select {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid #6c5ce7;
    background: #1a1a2e;
    color: white;
    font-size: 14px;
}

/* SEZIONE COMANDI */
.commands-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}

.command-category {
    background: rgba(108, 92, 231, 0.15);
    padding: 15px;
    border-radius: 10px;
    border: 1px solid #6c5ce7;
}

.command-category h4 {
    color: #6c5ce7;
    margin-bottom: 10px;
    font-size: 15px;
}

.command-list {
    list-style: none;
}

.command-list li {
    padding: 5px 0;
    font-size: 13px;
    color: #ddd;
}

/* MOBILE RESPONSIVE */
@media (max-width: 768px) {
    .container {
        flex-direction: column;
        gap: 0;
    }

    .sidebar {
        width: 100%;
        max-height: 150px;
        position: absolute;
        top: 60px;
        left: 0;
        right: 0;
        z-index: 500;
    }

    .box {
        width: 100%;
        max-height: calc(100vh - 70px);
    }

    .header-buttons {
        gap: 3px;
    }

    .header-buttons button {
        padding: 6px 10px;
        font-size: 12px;
    }

    #chat {
        padding: 10px;
        margin-bottom: 10px;
    }

    .modal-content {
        width: 95%;
        padding: 15px;
    }

    .commands-grid {
        grid-template-columns: 1fr;
    }

    .input-area {
        gap: 5px;
    }

    input[type="text"] {
        font-size: 16px; /* Previene zoom su iOS */
    }
}

@media (max-width: 480px) {
    body {
        padding: 5px;
    }

    .box {
        border-radius: 10px;
        padding: 10px;
    }

    .header {
        margin-bottom: 10px;
    }

    h2 {
        font-size: 18px;
    }

    button {
        padding: 8px 10px;
        font-size: 12px;
    }

    .modal-content {
        width: 98%;
        padding: 12px;
    }

    .tab-buttons {
        gap: 5px;
    }

    .tab-btn {
        padding: 8px 12px;
        font-size: 12px;
    }
}

.buttons-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.buttons-row button {
    flex: 1;
    min-width: 70px;
}

.toggle-sidebar {
    display: none;
}

@media (max-width: 768px) {
    .toggle-sidebar {
        display: block;
    }
}
</style>

</head>

<body>

<div class="container">
    <!-- SIDEBAR CHAT -->
    <div class="sidebar" id="sidebar">
        <h3>💬 Chat</h3>
        <div class="chat-list" id="chatList"></div>
    </div>

    <!-- BOX PRINCIPALE -->
    <div class="box">
        <!-- HEADER -->
        <div class="header">
            <h2>💜 MiniZenyla</h2>
            <div class="header-buttons">
                <button class="toggle-sidebar" onclick="toggleSidebar()">☰ Chat</button>
                <button onclick="toggleSettings()">⚙️ Impostazioni</button>
            </div>
        </div>

        <!-- CHAT AREA -->
        <div id="chat"></div>

        <!-- INPUT -->
        <div class="input-area">
            <input type="text" id="testo" placeholder="Scrivi qualcosa...">
            <button onclick="rispondi()">➤</button>
        </div>

        <!-- BUTTONS ROW -->
        <div class="buttons-row">
            <button onclick="cancellaChat()">🗑️ Svuota</button>
            <button id="voiceBtn" onclick="muta()">🔊 Voce</button>
            <button onclick="cercaGoogle()">🔍 Google</button>
        </div>
    </div>
</div>

<!-- MODALE IMPOSTAZIONI -->
<div class="modal" id="settingsModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>⚙️ Impostazioni</h2>
            <button class="close-btn" onclick="toggleSettings()">✕</button>
        </div>

        <!-- TABS -->
        <div class="tab-buttons">
            <button class="tab-btn active" onclick="switchTab('generale')">Generale</button>
            <button class="tab-btn" onclick="switchTab('comandi')">📖 Comandi</button>
            <button class="tab-btn" onclick="switchTab('api')">🔑 API</button>
        </div>

        <!-- TAB GENERALE -->
        <div id="generale" class="tab-content active">
            <h3>Preferenze Generali</h3>
            
            <div class="setting-item">
                <label>Lingua:</label>
                <button onclick="cambiaLingua()" style="width: 100%;">
                    <span id="btnLinguaText">🇬🇧 English</span>
                </button>
            </div>

            <div class="setting-item">
                <label>Tema:</label>
                <select id="tema">
                    <option value="scuro">🌙 Scuro</option>
                    <option value="chiaro">☀️ Chiaro</option>
                    <option value="viola">🟣 Viola</option>
                </select>
            </div>

            <div class="setting-item">
                <label>Animazioni:</label>
                <select id="animazioni">
                    <option value="on">✓ Abilitate</option>
                    <option value="off">✗ Disabilitate</option>
                </select>
            </div>

            <div class="setting-item">
                <label>Dimensione Font:</label>
                <input type="range" id="fontSize" min="12" max="20" value="14">
            </div>
        </div>

        <!-- TAB COMANDI -->
        <div id="comandi" class="tab-content">
            <h3>📖 Comandi Disponibili</h3>
            <div class="commands-grid" id="comandiGrid"></div>
        </div>

        <!-- TAB API -->
        <div id="api" class="tab-content">
            <h3>🔑 Configurazione API</h3>
            
            <div class="setting-item">
                <label>OpenAI API Key:</label>
                <input type="password" id="openaiKey" placeholder="sk-proj-...">
            </div>

            <div class="setting-item">
                <label>Bing Search API Key:</label>
                <input type="password" id="bingKey" placeholder="pub_...">
            </div>

            <button onclick="salvaApiKeys()" style="width: 100%; margin-top: 10px;">💾 Salva Chiavi</button>
            <p id="apiStatus" style="font-size: 12px; color: #6c5ce7; margin-top: 10px;"></p>
        </div>
    </div>
</div>

<script>

// ===== LINGUE COMPLETE =====
let linguaAttuale = localStorage.getItem("lingua") || "it";

let traduzioni = {
    it: {
        placeholder: "Scrivi qualcosa...",
        cancella: "🗑️ Svuota",
        voce: "🔊 Voce",
        muto: "🔇 Muto",
        btnLingua: "🇬🇧 English",
        comandi: {
            memoria: [
                "mi chiamo [nome] - Memorizza il tuo nome",
                "il mio colore preferito è [colore] - Salva il tuo colore",
                "il mio hobby è [hobby] - Ricorda il tuo hobby",
                "il mio cibo preferito è [cibo] - Salva il tuo cibo"
            ],
            utilità: [
                "che ore sono? - Ti dice l'ora",
                "che data è? - Ti dice la data",
                "dado - Tira un dado",
                "testa o croce - Lancia una moneta",
                "barzelletta - Racconta una barzelletta"
            ],
            ricerca: [
                "cerca [argomento] - Ricerca su Google",
                "chi sei? - Informazioni su MiniZenyla",
                "come stai? - Chiedi come sta"
            ],
            query: [
                "come mi chiamo? - Mostra il tuo nome",
                "qual è il mio colore preferito? - Mostra il tuo colore",
                "qual è il mio hobby? - Mostra il tuo hobby",
                "qual è il mio cibo preferito? - Mostra il tuo cibo"
            ]
        }
    },
    en: {
        placeholder: "Write something...",
        cancella: "🗑️ Clear",
        voce: "🔊 Voice",
        muto: "🔇 Mute",
        btnLingua: "🇮🇹 Italiano",
        comandi: {
            memoria: [
                "my name is [name] - Remember your name",
                "my favorite color is [color] - Save your color",
                "my hobby is [hobby] - Remember your hobby",
                "my favorite food is [food] - Save your food"
            ],
            utilità: [
                "what time is it? - Tell you the time",
                "what is the date? - Tell you the date",
                "dice - Roll a dice",
                "heads or tails - Flip a coin",
                "joke - Tell a joke"
            ],
            ricerca: [
                "search [topic] - Search on Google",
                "who are you? - About MiniZenyla",
                "how are you? - Ask how it is"
            ],
            query: [
                "what is my name? - Show your name",
                "what is my favorite color? - Show your color",
                "what is my hobby? - Show your hobby",
                "what is my favorite food? - Show your food"
            ]
        }
    }
};

function t(chiave) {
    return traduzioni[linguaAttuale][chiave] || chiave;
}

// ===== VARIABILI PRINCIPALI =====
let voceAttiva = JSON.parse(localStorage.getItem("voceAttiva") ?? "true");
let chatAttuale = localStorage.getItem("chatAttuale") || "Chat 1";
let listaChat = JSON.parse(localStorage.getItem("listaChat")) || ["Chat 1"];
let memoria = JSON.parse(localStorage.getItem("chat_" + chatAttuale)) || [];
let memoriaIA = JSON.parse(localStorage.getItem("memoriaIA")) || {
    nome: "", colore: "", hobby: "", cibo: ""
};

let animazioniAttive = localStorage.getItem("animazioni") !== "off";

// ===== UI FUNCTIONS =====
function toggleSettings() {
    let modal = document.getElementById("settingsModal");
    modal.classList.toggle("active");
}

function toggleSidebar() {
    let sidebar = document.getElementById("sidebar");
    sidebar.classList.toggle("active");
}

function switchTab(tabName) {
    // Nascondi tutti i tab
    document.querySelectorAll(".tab-content").forEach(tab => tab.classList.remove("active"));
    document.querySelectorAll(".tab-btn").forEach(btn => btn.classList.remove("active"));
    
    // Mostra il tab selezionato
    document.getElementById(tabName).classList.add("active");
    event.target.classList.add("active");
}

function cambiaLingua() {
    linguaAttuale = linguaAttuale === "it" ? "en" : "it";
    localStorage.setItem("lingua", linguaAttuale);
    document.getElementById("btnLinguaText").textContent = t("btnLingua");
    document.getElementById("testo").placeholder = t("placeholder");
    mostraChat();
    aggiornaListaChat();
    mostraComandi();
    aggiornaTasti();
}

function aggiornaTasti() {
    let btn = document.getElementById("voiceBtn");
    btn.textContent = voceAttiva ? t("voce") : t("muto");
}

// ===== CHAT FUNCTIONS =====
function mostraChat() {
    let chat = document.getElementById("chat");
    chat.innerHTML = "";
    
    memoria.forEach(m => {
        let coloreUtente = m.tipo === "Tu" ? "#7fb3d5" : "#6c5ce7";
        chat.innerHTML += `
        <div class="messaggio" style="border-left-color: ${coloreUtente}">
            <b>${m.tipo}:</b> ${m.testo}
        </div>`;
    });
    
    chat.scrollTop = chat.scrollHeight;
}

function salva(tipo, testo) {
    memoria.push({ tipo: tipo, testo: testo });
    localStorage.setItem("chat_" + chatAttuale, JSON.stringify(memoria));
    mostraChat();
    
    if(tipo === "Zenyla" && voceAttiva) {
        parla(testo);
    }
}

function rispondi() {
    let input = document.getElementById("testo");
    let testo = input.value.toLowerCase();
    
    if(testo === "") return;
    
    salva("Tu", testo);
    
    // Memoria intelligente
    if (testo.startsWith("mi chiamo ") || testo.startsWith("my name is ")) {
        let nome = testo.startsWith("mi chiamo ") ? testo.replace("mi chiamo ", "").trim() : testo.replace("my name is ", "").trim();
        memoriaIA.nome = nome;
        localStorage.setItem("memoriaIA", JSON.stringify(memoriaIA));
        salva("Zenyla", (linguaAttuale === "it" ? "Piacere di conoscerti, " : "Nice to meet you, ") + nome + (linguaAttuale === "it" ? "! 😊" : "! 😊"));
    }
    
    if (testo.startsWith("il mio colore preferito è ") || testo.startsWith("my favorite color is ")) {
        memoriaIA.colore = testo.startsWith("il mio colore preferito è ") ? testo.replace("il mio colore preferito è ", "") : testo.replace("my favorite color is ", "");
        localStorage.setItem("memoriaIA", JSON.stringify(memoriaIA));
    }
    
    if (testo.startsWith("il mio hobby è ") || testo.startsWith("my hobby is ")) {
        memoriaIA.hobby = testo.startsWith("il mio hobby è ") ? testo.replace("il mio hobby è ", "") : testo.replace("my hobby is ", "");
        localStorage.setItem("memoriaIA", JSON.stringify(memoriaIA));
    }
    
    if (testo.startsWith("il mio cibo preferito è ") || testo.startsWith("my favorite food is ")) {
        memoriaIA.cibo = testo.startsWith("il mio cibo preferito è ") ? testo.replace("il mio cibo preferito è ", "") : testo.replace("my favorite food is ", "");
        localStorage.setItem("memoriaIA", JSON.stringify(memoriaIA));
    }
    
    let sconosciute = ["Non ho capito 🤔", "Interessante!", "Puoi spiegarmi meglio?", "Questa è una domanda difficile 😅"];
    let risposta = sconosciute[Math.floor(Math.random() * sconosciute.length)];
    
    if(testo.includes("ciao") || testo.includes("hello")) risposta = "Ciao! 💜";
    else if(testo.includes("come stai")) risposta = "Sto funzionando bene! 🤖";
    else if(testo.includes("chi sei")) risposta = "Sono MiniZenyla, un'IA creata con JavaScript!";
    else if(testo.includes("nome")) risposta = "Il mio nome è MiniZenyla";
    else if(testo.includes("che ore sono") || testo.includes("what time")) risposta = (linguaAttuale === "it" ? "Sono le " : "It's ") + new Date().toLocaleTimeString();
    else if(testo.includes("data") || testo.includes("date")) risposta = (linguaAttuale === "it" ? "Oggi è " : "Today is ") + new Date().toLocaleDateString();
    else if(testo.includes("colore")) risposta = "Il viola 💜";
    else if(testo.includes("dado") || testo.includes("dice")) risposta = "🎲 " + (Math.floor(Math.random()*6)+1);
    else if(testo.includes("testa") || testo.includes("croce")) risposta = Math.random() < 0.5 ? "🪙 Testa" : "🪙 Croce";
    else if(testo.includes("barzelletta")) risposta = "Perché il computer è andato dal medico? Perché aveva un virus 😂";
    else if(testo.includes("come mi chiamo")) risposta = memoriaIA.nome ? "Ti chiami " + memoriaIA.nome : "Non me lo hai ancora detto";
    else if(testo.includes("colore preferito")) risposta = memoriaIA.colore ? "Il tuo colore è " + memoriaIA.colore : "Non me lo hai ancora detto";
    else if(testo.includes("hobby")) risposta = memoriaIA.hobby ? "Il tuo hobby è " + memoriaIA.hobby : "Non me lo hai ancora detto";
    else if(testo.includes("cibo preferito")) risposta = memoriaIA.cibo ? "Il tuo cibo è " + memoriaIA.cibo : "Non me lo hai ancora detto";
    
    if(risposta === sconosciute[0] && (testo.includes("cerca") || testo.includes("search"))) {
        cercaGoogle(testo);
        input.value = "";
        return;
    }
    
    salva("Zenyla", risposta);
    input.value = "";
}

function parla(testo) {
    let voce = new SpeechSynthesisUtterance(testo);
    voce.lang = linguaAttuale === "it" ? "it-IT" : "en-US";
    speechSynthesis.speak(voce);
}

function cancellaChat() {
    if(confirm(linguaAttuale === "it" ? "Cancellare questa chat?" : "Delete this chat?")) {
        memoria = [];
        localStorage.removeItem("chat_" + chatAttuale);
        mostraChat();
    }
}

function muta() {
    voceAttiva = !voceAttiva;
    localStorage.setItem("voceAttiva", voceAttiva);
    
    let btn = document.getElementById("voiceBtn");
    btn.classList.toggle("mutato");
    btn.classList.toggle("attivo");
    btn.textContent = voceAttiva ? t("voce") : t("muto");
    
    if(!voceAttiva) speechSynthesis.cancel();
    
    // Animazione di 5 secondi se attivo
    if(animazioniAttive) {
        btn.style.animation = "none";
        setTimeout(() => {
            btn.style.animation = "pulse 0.8s ease-in-out";
        }, 10);
    }
}

// ===== CHAT MULTIPLI =====
function aggiornaListaChat() {
    let chatList = document.getElementById("chatList");
    chatList.innerHTML = "";
    
    listaChat.forEach(chat => {
        let isActive = chat === chatAttuale;
        let item = document.createElement("div");
        item.className = "chat-item" + (isActive ? " active" : "");
        item.innerHTML = `
            ${chat}
            <button class="delete-btn" onclick="eliminaChat('${chat}', event)">✕</button>
        `;
        item.onclick = () => cambiaChat(chat);
        chatList.appendChild(item);
    });
}

function cambiaChat(nome) {
    chatAttuale = nome;
    localStorage.setItem("chatAttuale", nome);
    memoria = JSON.parse(localStorage.getItem("chat_" + nome)) || [];
    mostraChat();
    aggiornaListaChat();
}

function eliminaChat(nome, event) {
    event.stopPropagation();
    if(confirm(linguaAttuale === "it" ? `Eliminare "${nome}"?` : `Delete "${nome}"?`)) {
        listaChat = listaChat.filter(c => c !== nome);
        localStorage.setItem("listaChat", JSON.stringify(listaChat));
        localStorage.removeItem("chat_" + nome);
        
        if(chatAttuale === nome) {
            chatAttuale = listaChat[0] || "Chat 1";
            if(!listaChat.includes(chatAttuale)) {
                listaChat.push(chatAttuale);
                localStorage.setItem("listaChat", JSON.stringify(listaChat));
            }
        }
        
        cambiaChat(chatAttuale);
    }
}

// ===== COMANDI =====
function mostraComandi() {
    let grid = document.getElementById("comandiGrid");
    grid.innerHTML = "";
    let comandi = t("comandi");
    
    for(let categoria in comandi) {
        let div = document.createElement("div");
        div.className = "command-category";
        div.innerHTML = `
            <h4>📌 ${categoria === "memoria" ? "🧠 Memoria" : categoria === "utilità" ? "⚡ Utilità" : categoria === "ricerca" ? "🔍 Ricerca" : "❓ Query"}</h4>
            <ul class="command-list">
                ${comandi[categoria].map(cmd => `<li>• ${cmd}</li>`).join("")}
            </ul>
        `;
        grid.appendChild(div);
    }
}

// ===== API =====
function cercaGoogle(query) {
    let bingKey = localStorage.getItem("bing_key");
    if(!bingKey) {
        salva("Zenyla", "⚠️ Configura Bing Search API!");
        return;
    }
    
    salva("Zenyla", "🔍 Cercando...");
    let searchQuery = query.replace(/cerca |search /gi, "").trim();
    
    fetch(`https://api.bing.microsoft.com/v7.0/search?q=${encodeURIComponent(searchQuery)}`, {
        headers: { 'Ocp-Apim-Subscription-Key': bingKey }
    })
    .then(r => r.json())
    .then(data => {
        if(data.webPages && data.webPages.value.length > 0) {
            let risultato = data.webPages.value[0];
            memoria[memoria.length - 1].testo = `📌 ${risultato.name}\n${risultato.snippet}`;
            localStorage.setItem("chat_" + chatAttuale, JSON.stringify(memoria));
            mostraChat();
        }
    })
    .catch(() => {
        memoria[memoria.length - 1].testo = "❌ Errore nella ricerca";
        localStorage.setItem("chat_" + chatAttuale, JSON.stringify(memoria));
        mostraChat();
    });
}

function salvaApiKeys() {
    let openaiKey = document.getElementById("openaiKey").value.trim();
    let bingKey = document.getElementById("bingKey").value.trim();
    
    if(openaiKey) localStorage.setItem("openai_key", openaiKey);
    if(bingKey) localStorage.setItem("bing_key", bingKey);
    
    document.getElementById("openaiKey").value = "";
    document.getElementById("bingKey").value = "";
    
    let hasOpenAI = localStorage.getItem("openai_key") ? "✓" : "✗";
    let hasBing = localStorage.getItem("bing_key") ? "✓" : "✗";
    document.getElementById("apiStatus").innerHTML = `✅ OpenAI: ${hasOpenAI} | Bing: ${hasBing}`;
}

